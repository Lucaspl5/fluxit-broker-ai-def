// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Configuration for monitored symbols and analysis parameters
model configuration {
  id                    String    @id @default(cuid())
  symbol                String    @unique // e.g., "AAPL", "GOOGL"
  enabled               Boolean   @default(true)
  risk_profile          RiskProfile @default(MEDIUM) // BAJO, MEDIUM, ALTO
  analysis_interval_min Int       @default(15) // Minutes between analyses
  rsi_period            Int       @default(14)
  rsi_overbought        Int       @default(70)
  rsi_oversold          Int       @default(30)
  macd_fast_period      Int       @default(12)
  macd_slow_period      Int       @default(26)
  macd_signal_period    Int       @default(9)
  ma50_period           Int       @default(50)
  ma200_period          Int       @default(200)
  volume_threshold_pct  Decimal   @default(120) // Volume threshold as percentage of average
  required_convergence  Int       @default(4) // Number of indicators required for signal
  stop_loss_pct         Decimal   @default(2.0) // Stop loss percentage
  take_profit_pct       Decimal   @default(4.0) // Take profit percentage
  max_risk_per_trade    Decimal   @default(2.0) // Max EUR at risk per trade
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  signals               signal[]
  orders                order[]
  performances          performance[]

  @@index([enabled])
  @@index([risk_profile])
}

// Technical analysis signals
model signal {
  id                String        @id @default(cuid())
  configuration_id  String
  configuration     configuration @relation(fields: [configuration_id], references: [id], onDelete: Cascade)
  timestamp         DateTime      @default(now())
  symbol            String        @db.VarChar(10)
  signal_type       SignalType    // BUY or SELL
  rsi               Decimal       @db.Decimal(5, 2)
  macd              Decimal       @db.Decimal(10, 4)
  macd_signal       Decimal       @db.Decimal(10, 4)
  macd_divergence   Decimal?      @db.Decimal(10, 4) // MACD - Signal line
  ma50              Decimal       @db.Decimal(12, 4)
  ma200             Decimal       @db.Decimal(12, 4)
  current_price     Decimal       @db.Decimal(12, 4)
  volume            BigInt
  avg_volume        BigInt
  volume_ratio      Decimal       @db.Decimal(8, 2) // Current volume / average volume
  convergent_indicators Int
  convergence_score Int           // 0-4 score
  confidence_level  Decimal       @db.Decimal(5, 2) // Percentage
  risk_level        RiskLevel     // LOW, MEDIUM, HIGH
  reasoning         String        // Explanation of why signal was generated
  recommendation    String        // STRONG_BUY, BUY, NEUTRAL, SELL, STRONG_SELL
  telegram_message_id Int?        // Telegram message ID for tracking
  created_at        DateTime      @default(now())
  orders            order[]
  performances      performance[]

  @@index([symbol])
  @@index([timestamp])
  @@index([signal_type])
  @@index([confidence_level])
}

// Trading orders
model order {
  id                    String          @id @default(cuid())
  configuration_id      String
  configuration         configuration   @relation(fields: [configuration_id], references: [id], onDelete: Cascade)
  signal_id             String?
  signal                signal?         @relation(fields: [signal_id], references: [id], onDelete: SetNull)
  timestamp             DateTime        @default(now())
  symbol                String          @db.VarChar(10)
  order_type            OrderType       // BUY or SELL
  quantity              Decimal         @db.Decimal(10, 2)
  price                 Decimal         @db.Decimal(12, 4) // Price at time of order
  stop_loss_price       Decimal?        @db.Decimal(12, 4) // Auto stop loss
  take_profit_price     Decimal?        @db.Decimal(12, 4) // Auto take profit
  max_risk_eur          Decimal         @db.Decimal(10, 4) // Risk in EUR for this trade
  status                OrderStatus     @default(PENDING)
  status_reason         String?         // Why it's pending/rejected
  risk_level            RiskLevel?      // LOW, MEDIUM, HIGH
  alpaca_order_id       String?         // ID from Alpaca API
  user_authorization_time DateTime?
  execution_time        DateTime?
  telegram_callback_id  String?         // To track Telegram callback
  notes                 String?
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  performances          performance[]

  @@index([symbol])
  @@index([status])
  @@index([timestamp])
  @@index([risk_level])
}

// Performance and P&L tracking
model performance {
  id                String        @id @default(cuid())
  configuration_id  String
  configuration     configuration @relation(fields: [configuration_id], references: [id], onDelete: Cascade)
  buy_order_id      String
  buy_order         order         @relation(fields: [buy_order_id], references: [id], onDelete: Cascade)
  sell_order_id     String?
  signal_id         String?
  signal            signal?       @relation(fields: [signal_id], references: [id], onDelete: SetNull)
  symbol            String        @db.VarChar(10)
  entry_price       Decimal       @db.Decimal(12, 4)
  entry_time        DateTime
  exit_price        Decimal?      @db.Decimal(12, 4)
  exit_time         DateTime?
  quantity          Decimal       @db.Decimal(10, 2)
  profit_loss       Decimal?      @db.Decimal(12, 4) // Absolute P&L
  profit_loss_pct   Decimal?      @db.Decimal(8, 4)  // Percentage P&L
  duration_seconds  Int?          // Duration in seconds
  status            PerformanceStatus @default(OPEN)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  @@index([symbol])
  @@index([status])
  @@index([entry_time])
}

// Risk metrics and daily tracking
model riskMetrics {
  id                    String    @id @default(cuid())
  date                  DateTime  @db.Date
  trades_today          Int       @default(0)
  losses_today          Int       @default(0)
  total_daily_loss_eur  Decimal   @db.Decimal(10, 4)
  last_trade_time       DateTime?
  blacklist_until       DateTime? // When blacklist expires (2 hours after 2nd loss)
  is_blacklisted        Boolean   @default(false)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  @@unique([date])
  @@index([is_blacklisted])
}

enum SignalType {
  BUY
  SELL
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  AUTHORIZED
  EXECUTED
  FAILED
  CANCELLED
}

enum PerformanceStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum RiskProfile {
  BAJO     // Low risk: Blue Chip stocks
  MEDIUM   // Medium risk: Tech Growth
  ALTO     // High risk: Volatile stocks
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}
